<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>D MARK EVENT MANAGEMENT - Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <nav>
    <div class="nav-container">
      <div class="nav-brand">D MARK EVENT MANAGEMENT</div>
      <div class="nav-links">
        <a href="/admin/dashboard" class="active">Dashboard</a>
        <a href="/admin/events/create">Create Event</a>
        <a href="javascript:void(0)" onclick="toggleNotifications()" class="notif-bell" style="position:relative;">
          <i class="fas fa-bell"></i>
          <span id="notifBadge" class="notif-badge" style="<%= unreadCount > 0 ? '' : 'display:none;' %>"><%= unreadCount %></span>
        </a>
        <a href="/admin/logout">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <h1>Dashboard</h1>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= stats.event_count %></div>
        <div class="stat-label">Events</div>
      </div>
    </div>

    <div class="section">
      <div class="section-header">
        <h2>All Events</h2>
        <a href="/admin/events/create" class="btn btn-primary">Create Event</a>
      </div>

      <% if (events.length === 0) { %>
        <div class="empty-state">
          <p>No events yet. Create your first event to get started.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>Event Name</th>
                <th>Type</th>
                <th>People</th>
                <th>Date</th>
                <th>Contribution Link</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% events.forEach(event => {
                var isWedding = event.event_type === 'Wedding';
                var isTwoPerson = event.event_type === 'Wedding' || event.event_type === 'Anniversary';
                var personDisplay = isWedding ? (event.groom_name + ' & ' + event.bride_name) : isTwoPerson ? (event.person1_name + ' & ' + (event.person2_name || '')) : (event.person1_name || '');
              %>
                <tr>
                  <td><strong><%= event.name %></strong></td>
                  <td><span class="event-type-label"><%= event.event_type || 'Wedding' %></span></td>
                  <td><%= personDisplay %></td>
                  <td><%= event.event_date || '-' %></td>
                  <td><a href="/c/<%= event.unique_link %>" target="_blank" class="link">Open Link</a></td>
                  <td>
                    <a href="/admin/events/<%= event.id %>" class="btn btn-sm btn-secondary">View</a>
                    <button onclick="deleteEvent(<%= event.id %>, '<%= event.name.replace(/'/g, "\\'") %>')" class="btn btn-sm" style="background:#c62828;color:#fff;margin-left:0.25rem;"><i class="fas fa-trash"></i></button>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <div id="notifPanel" class="notif-panel">
    <div class="notif-panel-header">
      <h3>Notifications</h3>
      <button onclick="markAllRead()" class="btn btn-sm" style="background:none;color:#1a237e;font-size:0.75rem;padding:0;"><i class="fas fa-check-double"></i> Mark all read</button>
    </div>
    <div id="notifList" class="notif-list">
      <p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;">Loading...</p>
    </div>
  </div>
  <div id="notifOverlay" class="notif-overlay" onclick="closeNotifications()"></div>

  <script>
    function deleteEvent(id, name) {
      if (confirm('Delete "' + name + '" and all its contributions? This cannot be undone.')) {
        fetch('/admin/events/' + id + '/delete', { method: 'POST' })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.success) { window.location.reload(); }
            else { alert('Failed: ' + (d.error || 'Unknown')); }
          })
          .catch(function() { alert('Failed to delete'); });
      }
    }

    function toggleNotifications() {
      var panel = document.getElementById('notifPanel');
      var overlay = document.getElementById('notifOverlay');
      if (panel.classList.contains('open')) {
        panel.classList.remove('open');
        overlay.style.display = 'none';
      } else {
        loadNotifications();
        panel.classList.add('open');
        overlay.style.display = 'block';
      }
    }

    function closeNotifications() {
      document.getElementById('notifPanel').classList.remove('open');
      document.getElementById('notifOverlay').style.display = 'none';
    }

    function loadNotifications() {
      var list = document.getElementById('notifList');
      list.innerHTML = '<p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;">Loading...</p>';
      fetch('/api/notifications')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          list.innerHTML = '';
          if (data.notifications.length === 0) {
            list.innerHTML = '<p style="text-align:center;color:#888;padding:2rem;font-size:0.85rem;">No notifications yet.</p>';
            return;
          }
          data.notifications.forEach(function(n) {
            var d = new Date(n.created_at);
            var dateStr = d.toLocaleDateString() + ' ' + d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
            var icon = n.type === 'new_promise' ? 'fa-handshake' : n.type === 'new_cash' ? 'fa-money-bill' : 'fa-check-circle';
            var item = document.createElement('div');
            item.className = 'notif-item' + (n.is_read ? '' : ' unread');
            item.innerHTML =
              '<div class="notif-icon"><i class="fas ' + icon + '"></i></div>' +
              '<div class="notif-body"><div class="notif-msg">' + n.message + '</div><div class="notif-time">' + dateStr + '</div></div>';
            list.appendChild(item);
          });
          document.getElementById('notifBadge').style.display = 'none';
        })
        .catch(function() {
          list.innerHTML = '<p style="text-align:center;color:#c62828;padding:1rem;font-size:0.85rem;">Failed to load.</p>';
        });
    }

    function markAllRead() {
      fetch('/api/notifications/read', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(d) {
          if (d.success) {
            document.querySelectorAll('#notifList .notif-item').forEach(function(el) { el.classList.remove('unread'); });
          }
        })
        .catch(function() {});
    }
  </script>
</body>
</html>