<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= __('brand') %> - <%= __('resetPassword') %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#1a237e">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&family=Montserrat:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .lang-toggle-login { font-size:0.75rem; font-weight:600; padding:0.3rem 0.7rem; border-radius:4px; border:1.5px solid rgba(255,255,255,0.3); color:#fff; background:transparent; cursor:pointer; transition:0.2s; position:absolute; top:1rem; right:1rem; }
    .lang-toggle-login:hover { background:rgba(255,255,255,0.1); }
    .password-card { max-width:480px; margin:2rem auto; background:#fff; border-radius:8px; padding:2rem; box-shadow:0 2px 12px rgba(0,0,0,0.08); }
    .password-card h2 { margin-top:0; font-size:1.3rem; color:#1a237e; }
    .form-group { margin-bottom:1.2rem; }
    .form-group label { display:block; font-weight:600; margin-bottom:0.3rem; font-size:0.85rem; color:#444; }
    .form-group input { width:100%; padding:0.6rem 0.8rem; border:1.5px solid #ddd; border-radius:6px; font-size:0.95rem; box-sizing:border-box; }
    .form-group input:focus { border-color:#1a237e; outline:none; box-shadow:0 0 0 2px rgba(26,35,126,0.12); }
    .alert { padding:0.7rem 1rem; border-radius:6px; margin-bottom:1rem; font-size:0.9rem; }
    .alert-success { background:#e8f5e9; color:#2e7d32; border:1px solid #a5d6a7; }
    .alert-error { background:#fbe9e7; color:#c62828; border:1px solid #ef9a9a; }
    .hint { font-size:0.8rem; color:#888; margin-bottom:0.5rem; }
    .btn-save { background:linear-gradient(135deg,#1a237e,#283593); color:#fff; border:none; padding:0.7rem 1.5rem; border-radius:6px; font-size:0.95rem; font-weight:600; cursor:pointer; transition:0.2s; width:100%; }
    .btn-save:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(26,35,126,0.3); }
    .back-link { display:block; text-align:center; margin-top:1rem; color:#1a237e; text-decoration:none; font-size:0.9rem; }
    .back-link:hover { text-decoration:underline; }
  </style>
</head>
<body class="login-page">
  <button onclick="toggleLang()" class="lang-toggle-login"><%= lang === 'sw' ? 'English' : 'Kiswahili' %></button>
  <div class="login-bg-shapes">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
  </div>
  <div class="login-container">
    <div class="login-header">
      <div class="login-icon">
        <i class="fas fa-key"></i>
      </div>
      <h1><%= __('resetPassword') %></h1>
      <p class="login-subtitle"><%= __('brand') %></p>
      <div class="login-divider">
        <span class="divider-line"></span>
        <span class="divider-diamond">&#9670;</span>
        <span class="divider-line"></span>
      </div>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
      <div style="text-align:center;margin-top:1rem;"><a href="/admin/login" class="btn-save" style="display:inline-block;width:auto;padding:0.7rem 2rem;"><%= __('login') %></a></div>
    <% } else { %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <p class="hint"><%= __('recoveryCodeNote') %></p>

      <form method="POST" action="/admin/reset-password">
        <div class="form-group">
          <div class="input-wrapper">
            <i class="fas fa-user input-icon"></i>
            <input type="text" id="username" name="username" required placeholder="<%= __('username') %>" autocomplete="username">
          </div>
        </div>
        <div class="form-group">
          <div class="input-wrapper">
            <i class="fas fa-shield-alt input-icon"></i>
            <input type="text" id="recovery_code" name="recovery_code" required placeholder="<%= __('recoveryCode') %>">
          </div>
        </div>
        <div class="form-group">
          <div class="input-wrapper">
            <i class="fas fa-lock input-icon"></i>
            <input type="password" id="new_password" name="new_password" required minlength="4" placeholder="<%= __('newPassword2') %>" autocomplete="new-password">
          </div>
        </div>
        <div class="form-group">
          <div class="input-wrapper">
            <i class="fas fa-lock input-icon"></i>
            <input type="password" id="confirm_password" name="confirm_password" required minlength="4" placeholder="<%= __('confirmPassword') %>" autocomplete="new-password">
          </div>
        </div>
        <button type="submit" class="btn-save"><%= __('resetPassword') %></button>
      </form>
      <a href="/admin/login" class="back-link"><%= __('login') %></a>
    <% } %>
  </div>

  <script>
    function toggleLang() {
      var newLang = '<%= lang %>' === 'sw' ? 'en' : 'sw';
      fetch('/lang/' + newLang, { method: 'POST' })
        .then(function(r){return r.json()})
        .then(function(d){if(d.success)window.location.reload()})
        .catch(function(){});
    }
  </script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/service-worker.js').catch(function(){});
    }
  </script>
</body>
</html>