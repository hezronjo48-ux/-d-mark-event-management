<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Debtors - D MARK EVENT MANAGEMENT</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .event-section { margin-bottom: 2rem; }
    .event-section h3 { font-size:1rem; color:#1a237e; margin-bottom:0.5rem; border-bottom:2px solid #e0e0e0; padding-bottom:0.4rem; }
    .event-section .event-total { font-size:0.8rem; color:#888; margin-bottom:0.8rem; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-container">
      <div class="nav-brand">D MARK EVENT MANAGEMENT</div>
      <div class="nav-links">
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/events/create">Create Event</a>
        <a href="/admin/debtors" class="active">Debtors</a>
        <a href="/admin/activity-log">Activity Log</a>
        <a href="javascript:void(0)" onclick="toggleNotifications()" class="notif-bell" style="position:relative;">
          <i class="fas fa-bell"></i>
          <span id="notifBadge" class="notif-badge" style="<%= unreadCount > 0 ? '' : 'display:none;' %>"><%= unreadCount %></span>
        </a>
        <a href="/admin/logout">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1>Debtors List</h1>
      <p style="color:#888;font-size:0.85rem;">Contributors with incomplete promises, grouped by event</p>
    </div>

    <% var allKeys = Object.keys(grouped); %>
    <% var totalOutstanding = 0; allKeys.forEach(function(k) { grouped[k].forEach(function(d) { totalOutstanding += Number(d.remaining_balance||0); }); }); %>

    <div class="stats-grid" style="margin-bottom:1.5rem;">
      <div class="stat-card">
        <div class="stat-value"><%= allKeys.length %></div>
        <div class="stat-label">Events with Debtors</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">TZS <%= Number(totalOutstanding).toLocaleString() %></div>
        <div class="stat-label">Total Outstanding</div>
      </div>
    </div>

    <% if (allKeys.length === 0) { %>
      <div class="empty-state"><p>No debtors. All promises fulfilled!</p></div>
    <% } else { %>
      <% allKeys.forEach(function(eventName) { %>
        <% var evDebtors = grouped[eventName]; %>
        <% var evTotal = evDebtors.reduce(function(s,c){ return s + Number(c.remaining_balance||0); }, 0); %>
        <div class="event-section">
          <h3><%= eventName %></h3>
          <div class="event-total"><%= evDebtors.length %> debtor(s) — TZS <%= Number(evTotal).toLocaleString() %> outstanding</div>
          <div class="table-responsive">
            <table class="table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Name</th>
                  <th>Phone</th>
                  <th>Promised (TZS)</th>
                  <th>Paid (TZS)</th>
                  <th>Balance (TZS)</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% evDebtors.forEach(function(d) { %>
                  <tr>
                    <td><span class="contributor-id-badge"><%= d.contributor_id || '-' %></span></td>
                    <td><strong><%= d.full_name %></strong></td>
                    <td>
                      <% if (d.phone_number) { %>
                        <a href="tel:<%= d.phone_number %>" style="color:#1a237e;"><i class="fas fa-phone"></i> <%= d.phone_number %></a>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td><%= Number(d.promise_amount).toLocaleString() %></td>
                    <td><%= Number(d.paid_amount).toLocaleString() %></td>
                    <td><strong style="color:#c62828;"><%= Number(d.remaining_balance).toLocaleString() %></strong></td>
                    <td><a href="/admin/events/<%= d.event_id %>/contributors/<%= d.id %>" class="btn btn-sm btn-secondary"><i class="fas fa-eye"></i></a></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>

  <div id="notifPanel" class="notif-panel">
    <div class="notif-panel-header">
      <h3>Notifications</h3>
      <button onclick="markAllRead()" class="btn btn-sm" style="background:none;color:#1a237e;font-size:0.75rem;padding:0;"><i class="fas fa-check-double"></i> Mark all read</button>
    </div>
    <div id="notifList" class="notif-list"><p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;">Loading...</p></div>
  </div>
  <div id="notifOverlay" class="notif-overlay" onclick="closeNotifications()"></div>

  <script>
    function toggleNotifications() {
      var panel = document.getElementById('notifPanel');
      var overlay = document.getElementById('notifOverlay');
      if (panel.classList.contains('open')) { panel.classList.remove('open'); overlay.style.display = 'none'; }
      else { loadNotifications(); panel.classList.add('open'); overlay.style.display = 'block'; }
    }
    function closeNotifications() {
      document.getElementById('notifPanel').classList.remove('open');
      document.getElementById('notifOverlay').style.display = 'none';
    }
    function loadNotifications() {
      var list = document.getElementById('notifList');
      list.innerHTML = '<p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;">Loading...</p>';
      fetch('/api/notifications').then(function(r){return r.json()}).then(function(data){
        list.innerHTML = '';
        if (data.notifications.length === 0) { list.innerHTML = '<p style="text-align:center;color:#888;padding:2rem;font-size:0.85rem;">No notifications yet.</p>'; return; }
        data.notifications.forEach(function(n){
          var d=new Date(n.created_at); var ds=d.toLocaleDateString()+' '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
          var icon=n.type==='new_promise'?'fa-handshake':n.type==='new_cash'?'fa-money-bill':'fa-check-circle';
          var item=document.createElement('div'); item.className='notif-item'+(n.is_read?'':' unread');
          item.innerHTML='<div class="notif-icon"><i class="fas '+icon+'"></i></div><div class="notif-body"><div class="notif-msg">'+n.message+'</div><div class="notif-time">'+ds+'</div></div>';
          list.appendChild(item);
        });
        document.getElementById('notifBadge').style.display='none';
      }).catch(function(){ list.innerHTML='<p style="text-align:center;color:#c62828;padding:1rem;font-size:0.85rem;">Failed to load.</p>'; });
    }
    function markAllRead() {
      fetch('/api/notifications/read',{method:'POST'}).then(function(r){return r.json()}).then(function(d){if(d.success){document.querySelectorAll('#notifList .notif-item').forEach(function(el){el.classList.remove('unread');});}}).catch(function(){});
    }
  </script>
</body>
</html>
