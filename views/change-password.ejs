<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= __('brand') %> - <%= __('changePassword') %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#1a237e">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&family=Montserrat:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .lang-toggle { font-size:0.75rem; font-weight:600; padding:0.25rem 0.6rem; border-radius:4px; border:1.5px solid rgba(255,255,255,0.4); color:#fff; background:transparent; cursor:pointer; transition:0.2s; }
    .lang-toggle:hover { background:rgba(255,255,255,0.15); }
    .password-card { max-width:480px; margin:2rem auto; background:#fff; border-radius:8px; padding:2rem; box-shadow:0 2px 12px rgba(0,0,0,0.08); }
    .password-card h2 { margin-top:0; font-size:1.3rem; color:#1a237e; }
    .form-group { margin-bottom:1.2rem; }
    .form-group label { display:block; font-weight:600; margin-bottom:0.3rem; font-size:0.85rem; color:#444; }
    .form-group input { width:100%; padding:0.6rem 0.8rem; border:1.5px solid #ddd; border-radius:6px; font-size:0.95rem; box-sizing:border-box; }
    .form-group input:focus { border-color:#1a237e; outline:none; box-shadow:0 0 0 2px rgba(26,35,126,0.12); }
    .alert { padding:0.7rem 1rem; border-radius:6px; margin-bottom:1rem; font-size:0.9rem; }
    .alert-success { background:#e8f5e9; color:#2e7d32; border:1px solid #a5d6a7; }
    .alert-error { background:#fbe9e7; color:#c62828; border:1px solid #ef9a9a; }
    .recovery-section { margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid #eee; }
    .recovery-section summary { cursor:pointer; font-size:0.85rem; color:#1a237e; font-weight:600; }
    .recovery-section .hint { font-size:0.8rem; color:#888; margin-top:0.3rem; }
    .btn-save { background:linear-gradient(135deg,#1a237e,#283593); color:#fff; border:none; padding:0.7rem 1.5rem; border-radius:6px; font-size:0.95rem; font-weight:600; cursor:pointer; transition:0.2s; }
    .btn-save:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(26,35,126,0.3); }
    .btn-secondary { display:inline-block; background:#f5f5f5; color:#333; padding:0.6rem 1.2rem; border-radius:6px; text-decoration:none; font-size:0.9rem; font-weight:500; margin-left:0.5rem; }
    .btn-secondary:hover { background:#eee; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-container">
      <div class="nav-brand"><%= __('brand') %></div>
      <div class="nav-links">
        <a href="/admin/dashboard"><%= __('dashboard') %></a>
        <a href="/admin/events/create"><%= __('createEvent') %></a>
        <a href="/admin/debtors"><%= __('debtors') %></a>
        <a href="/admin/activity-log"><%= __('activityLog') %></a>
        <a href="/admin/change-password" class="active"><%= __('changePassword') %></a>
        <a href="javascript:void(0)" onclick="toggleLang()" class="lang-toggle"><%= lang === 'sw' ? 'EN' : 'SW' %></a>
        <a href="/admin/logout"><%= __('logout') %></a>
      </div>
    </div>
  </nav>

  <div class="container">
    <h1><%= __('changePassword') %></h1>

    <div class="password-card">
      <h2><%= __('changePassword') %></h2>

      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/change-password">
        <div class="form-group">
          <label for="current_password"><%= __('currentPassword') %></label>
          <input type="password" id="current_password" name="current_password" required autocomplete="current-password">
        </div>
        <div class="form-group">
          <label for="new_password"><%= __('newPassword') %></label>
          <input type="password" id="new_password" name="new_password" required minlength="4" autocomplete="new-password">
        </div>
        <div class="form-group">
          <label for="confirm_password"><%= __('confirmPassword') %></label>
          <input type="password" id="confirm_password" name="confirm_password" required minlength="4" autocomplete="new-password">
        </div>

        <details class="recovery-section">
          <summary><%= __('recoveryCode') %></summary>
          <p class="hint"><%= __('recoveryCodeNote') %></p>
          <div class="form-group">
            <input type="text" id="recovery_code" name="recovery_code" placeholder="<%= __('recoveryCode') %>">
          </div>
        </details>

        <div style="margin-top:1rem;">
          <button type="submit" class="btn-save"><%= __('save') %></button>
          <a href="/admin/dashboard" class="btn-secondary"><%= __('cancel') %></a>
        </div>
      </form>
    </div>
  </div>

  <script>
    function toggleLang() {
      var newLang = '<%= lang %>' === 'sw' ? 'en' : 'sw';
      fetch('/lang/' + newLang, { method: 'POST' })
        .then(function(r){return r.json()})
        .then(function(d){if(d.success)window.location.reload()})
        .catch(function(){});
    }
  </script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/service-worker.js').catch(function(){});
    }
  </script>
</body>
</html>