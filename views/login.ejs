<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= __('brand') %> - <%= __('adminLogin') %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#1a237e">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&family=Montserrat:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .lang-toggle-login { font-size:0.75rem; font-weight:600; padding:0.3rem 0.7rem; border-radius:4px; border:1.5px solid rgba(255,255,255,0.3); color:#fff; background:transparent; cursor:pointer; transition:0.2s; position:absolute; top:1rem; right:1rem; }
    .lang-toggle-login:hover { background:rgba(255,255,255,0.1); }
  </style>
</head>
<body class="login-page">
  <button onclick="toggleLang()" class="lang-toggle-login"><%= lang === 'sw' ? 'English' : 'Kiswahili' %></button>
  <div class="login-bg-shapes">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
  </div>
  <div class="login-container">
    <div class="login-header">
      <div class="login-icon">
        <i class="fas fa-ring"></i>
      </div>
      <h1><%= __('brand') %></h1>
      <p class="login-subtitle"><%= __('contributionMgmt') %></p>
      <div class="login-divider">
        <span class="divider-line"></span>
        <span class="divider-diamond">&#9670;</span>
        <span class="divider-line"></span>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login" class="login-form">
      <div class="form-group">
        <div class="input-wrapper">
          <i class="fas fa-user input-icon"></i>
          <input type="text" id="username" name="username" required placeholder="<%= __('username') %>" autocomplete="username">
        </div>
      </div>
      <div class="form-group">
        <div class="input-wrapper">
          <i class="fas fa-lock input-icon"></i>
          <input type="password" id="password" name="password" required placeholder="<%= __('password') %>" autocomplete="current-password">
        </div>
      </div>
      <button type="submit" class="btn-login">
        <span><%= __('login') %></span>
        <i class="fas fa-arrow-right"></i>
      </button>
      <div style="text-align:center;margin-top:0.8rem;">
        <a href="/admin/reset-password" style="color:rgba(255,255,255,0.7);font-size:0.85rem;text-decoration:none;"><%= __('forgotPassword') %></a>
      </div>
    </form>
    <p class="login-footer"><%= __('brand') %></p>
  </div>

  <script>
    function toggleLang() {
      var newLang = '<%= lang %>' === 'sw' ? 'en' : 'sw';
      fetch('/lang/' + newLang, { method: 'POST' })
        .then(function(r){return r.json()})
        .then(function(d){if(d.success)window.location.reload()})
        .catch(function(){});
    }
  </script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/service-worker.js').catch(function(){});
    }
  </script>
</body>
</html>
