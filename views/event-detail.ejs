<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>D MARK EVENT MANAGEMENT - <%= event.name %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <nav>
    <div class="nav-container">
      <div class="nav-brand">D MARK EVENT MANAGEMENT</div>
      <div class="nav-links">
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/events/create">Create Event</a>
        <a href="javascript:void(0)" onclick="toggleNotifications()" class="notif-bell" style="position:relative;">
          <i class="fas fa-bell"></i>
          <span id="notifBadge" class="notif-badge" style="<%= unreadCount > 0 ? '' : 'display:none;' %>"><%= unreadCount %></span>
        </a>
        <a href="/admin/logout">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <a href="/admin/dashboard" class="back-link">&larr; Back to Dashboard</a>
    </div>

    <div class="event-card">
      <h1><%= event.name %></h1>
      <div class="event-details">
        <p><span class="label">Type:</span> <span class="event-type-label"><%= event.event_type || 'Wedding' %></span></p>
        <% if (event.event_type === 'Wedding') { %>
          <p><span class="label">Groom:</span> <%= event.groom_name %></p>
          <p><span class="label">Bride:</span> <%= event.bride_name %></p>
        <% } else if (event.event_type === 'Anniversary') { %>
          <p><span class="label">Person 1:</span> <%= event.person1_name %></p>
          <p><span class="label">Person 2:</span> <%= event.person2_name %></p>
        <% } else { %>
          <p><span class="label">Name:</span> <%= event.person1_name %></p>
        <% } %>
        <% if (event.event_date) { %>
          <p><span class="label">Date:</span> <%= new Date(event.event_date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
        <% } %>
        <% if (event.venue) { %>
          <p><span class="label">Venue:</span> <%= event.venue %></p>
        <% } %>
      </div>

      <div style="margin-top:1rem;display:flex;gap:0.5rem;">
        <button onclick="confirmDelete()" class="btn btn-sm" style="background:#c62828;color:#fff;"><i class="fas fa-trash"></i> Delete Event</button>
      </div>

      <div class="link-section">
        <label>Contribution Link</label>
        <div class="link-copy">
          <input type="text" id="contributionLink" value="<%= contributionLink %>" readonly>
          <a href="<%= contributionLink %>" target="_blank" class="btn btn-sm btn-secondary"><i class="fas fa-external-link-alt"></i> Open</a>
          <button class="btn btn-sm btn-secondary" onclick="copyLink()"><i class="fas fa-copy"></i> Copy</button>
        </div>
        <p style="font-size:0.8rem;color:#888;margin-top:0.5rem;">Share this link with guests to collect contributions.</p>
      </div>

      <div class="link-section" style="border-top-color:#e8eaf6;">
        <label>Event Management Link <span style="font-weight:400;color:#888;font-size:0.75rem;">(for event owner — no login needed)</span></label>
        <div class="link-copy">
          <input type="text" id="manageLink" value="<%= manageLink %>" readonly>
          <a href="<%= manageLink %>" target="_blank" class="btn btn-sm btn-secondary"><i class="fas fa-external-link-alt"></i> Open</a>
          <button class="btn btn-sm btn-secondary" onclick="copyManageLink()"><i class="fas fa-copy"></i> Copy</button>
        </div>
        <p style="font-size:0.8rem;color:#888;margin-top:0.5rem;">The event owner can view stats, contributions, and export without logging in.</p>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value">TZS <%= Number(stats.total_promised).toLocaleString() %></div>
        <div class="stat-label">Total Promised</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">TZS <%= Number(stats.total_paid).toLocaleString() %></div>
        <div class="stat-label">Total Collected</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">TZS <%= Number(stats.total_remaining).toLocaleString() %></div>
        <div class="stat-label">Total Remaining</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.contributor_count %></div>
        <div class="stat-label">Contributors</div>
      </div>
    </div>

    <% if (targetAmount > 0) { %>
    <div class="event-card" style="margin-bottom:1rem;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem;">
        <strong>Contribution Goal</strong>
        <span style="font-size:0.9rem;color:#666;">TZS <%= Number(stats.total_paid).toLocaleString() %> / TZS <%= Number(targetAmount).toLocaleString() %></span>
      </div>
      <div class="progress-bar-container">
        <div class="progress-bar-fill" style="width:<%= progressPercent %>%;"><%= progressPercent %>%</div>
      </div>
    </div>
    <% } %>

    <div class="section">
      <div class="section-header">
        <h2>Contributions</h2>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          <button onclick="document.getElementById('manualEntrySection').style.display = document.getElementById('manualEntrySection').style.display === 'none' ? 'block' : 'none'" class="btn btn-sm btn-secondary"><i class="fas fa-user-plus"></i> Manual Entry</button>
          <a href="/admin/export/<%= event.id %>" class="btn btn-sm btn-gold">Export Excel</a>
        </div>
      </div>

      <div id="manualEntrySection" class="form-card" style="display:none;margin-bottom:1rem;max-width:100%;">
        <h3 style="margin-bottom:1rem;">Manual Contribution Entry</h3>
        <form id="manualEntryForm" style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
          <div class="form-group" style="margin:0;">
            <label>Full Name *</label>
            <input type="text" id="manual_name" required placeholder="Full name">
          </div>
          <div class="form-group" style="margin:0;">
            <label>Phone Number</label>
            <input type="text" id="manual_phone" placeholder="Phone number">
          </div>
          <div class="form-group" style="margin:0;">
            <label>Type *</label>
            <select id="manual_type" onchange="toggleManualType()">
              <option value="cash">Cash</option>
              <option value="promise">Promise</option>
            </select>
          </div>
          <div class="form-group" style="margin:0;" id="manual_promise_group">
            <label>Promise Amount (TZS) *</label>
            <input type="number" id="manual_promise" min="1" step="1" placeholder="Promise amount">
          </div>
          <div class="form-group" style="margin:0;" id="manual_cash_group">
            <label>Amount Paid (TZS) *</label>
            <input type="number" id="manual_amount" min="1" step="1" placeholder="Amount paid">
          </div>
          <div class="form-group" style="margin:0;">
            <label>Payment Method</label>
            <select id="manual_method">
              <option value="">Select</option>
              <option value="Vodacom M-Pesa">Vodacom M-Pesa</option>
              <option value="Airtel Money">Airtel Money</option>
              <option value="Mixx by Yas">Mixx by Yas</option>
              <option value="HaloPesa">HaloPesa</option>
              <option value="Bank">Bank</option>
              <option value="Cash">Cash</option>
            </select>
          </div>
          <div class="form-group" style="margin:0;">
            <label>Sender Name</label>
            <input type="text" id="manual_sender" placeholder="Sender name">
          </div>
          <div style="grid-column:1/-1;">
            <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-save"></i> Save</button>
            <span id="manualStatus" class="result-message" style="display:inline;margin-left:0.5rem;"></span>
          </div>
        </form>
      </div>

      <div class="search-bar" style="display:flex;gap:0.5rem;margin-bottom:1rem;flex-wrap:wrap;align-items:center;">
        <input type="text" id="searchInput" placeholder="Search by ID, name, or phone..." style="flex:1;min-width:200px;padding:0.5rem 0.75rem;font-size:0.85rem;border:1.5px solid #e0e0e0;border-radius:6px;font-family:'Inter',sans-serif;">
        <select id="filterType" style="padding:0.5rem 0.75rem;font-size:0.85rem;border:1.5px solid #e0e0e0;border-radius:6px;font-family:'Inter',sans-serif;">
          <option value="">All Types</option>
          <option value="Promise">Promise</option>
          <option value="Cash">Cash</option>
        </select>
        <select id="filterStatus" style="padding:0.5rem 0.75rem;font-size:0.85rem;border:1.5px solid #e0e0e0;border-radius:6px;font-family:'Inter',sans-serif;">
          <option value="">All Status</option>
          <option value="Done">Done</option>
          <option value="Incomplete">Incomplete</option>
        </select>
        <span style="font-size:0.8rem;color:#888;" id="filterCount"></span>
      </div>

      <% if (contributors.length === 0) { %>
        <div class="empty-state">
          <p>No contributions yet. Share the contribution link with your guests.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table" id="contributorsTable">
            <thead>
              <tr>
                <th>ID</th>
                <th>Full Name</th>
                <th>Phone</th>
                <th>Type</th>
                <th>Promise (TZS)</th>
                <th>Paid (TZS)</th>
                <th>Balance (TZS)</th>
                <th>Payment Method</th>
                <th>Status</th>
                <th>Notes</th>
                <th>Date</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% contributors.forEach(c => { %>
                <tr data-type="<%= c.contribution_type %>" data-status="<%= c.status %>" data-search="<%= (c.contributor_id || '') + ' ' + c.full_name + ' ' + (c.phone_number || '') %>">
                  <td><span class="contributor-id-badge"><%= c.contributor_id || '-' %></span></td>
                  <td><%= c.full_name %></td>
                  <td><%= c.phone_number || '-' %></td>
                  <td><%= c.contribution_type %></td>
                  <td><%= c.promise_amount > 0 ? Number(c.promise_amount).toLocaleString() : '-' %></td>
                  <td><%= Number(c.paid_amount).toLocaleString() %></td>
                  <td><%= Number(c.remaining_balance).toLocaleString() %></td>
                  <td><%= c.payment_method || '-' %></td>
                  <td>
                    <span class="badge <%= c.status === 'Done' ? 'badge-success' : 'badge-warning' %>">
                      <%= c.status %>
                    </span>
                  </td>
                  <td><%= c.notes ? (c.notes.length > 20 ? c.notes.substring(0,20) + '...' : c.notes) : '-' %></td>
                  <td><%= new Date(c.created_at).toLocaleDateString() %></td>
                  <td><a href="/admin/events/<%= event.id %>/contributors/<%= c.id %>" class="btn btn-sm btn-secondary"><i class="fas fa-eye"></i></a></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    function copyLink() {
      const input = document.getElementById('contributionLink');
      input.select();
      document.execCommand('copy');
      const btn = event.target;
      const orig = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
      setTimeout(() => { btn.innerHTML = orig; }, 2000);
    }
    function copyManageLink() {
      const input = document.getElementById('manageLink');
      input.select();
      document.execCommand('copy');
      const btn = event.target;
      const orig = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
      setTimeout(() => { btn.innerHTML = orig; }, 2000);
    }
    function confirmDelete() {
      if (confirm('Are you sure you want to delete this event and all its contributions? This cannot be undone.')) {
        fetch('/admin/events/<%= event.id %>/delete', { method: 'POST' })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.success) { window.location.href = '/admin/dashboard'; }
            else { alert('Failed to delete: ' + (d.error || 'Unknown error')); }
          })
          .catch(function() { alert('Failed to delete event'); });
      }
    }

    function toggleManualType() {
      var type = document.getElementById('manual_type').value;
      document.getElementById('manual_promise_group').style.display = type === 'promise' ? 'block' : 'none';
      document.getElementById('manual_cash_group').style.display = type === 'cash' ? 'block' : 'none';
    }
    document.addEventListener('DOMContentLoaded', toggleManualType);

    document.getElementById('manualEntryForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var data = {
        full_name: document.getElementById('manual_name').value,
        phone_number: document.getElementById('manual_phone').value,
        contribution_type: document.getElementById('manual_type').value,
        promise_amount: document.getElementById('manual_promise').value,
        amount_paid: document.getElementById('manual_amount').value,
        payment_method: document.getElementById('manual_method').value,
        sender_name: document.getElementById('manual_sender').value
      };
      fetch('/admin/events/<%= event.id %>/contributors/manual', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var status = document.getElementById('manualStatus');
        if (d.success) {
          status.className = 'result-message success';
          status.textContent = 'Added!';
          status.style.display = 'inline';
          setTimeout(function() { window.location.reload(); }, 1000);
        } else {
          status.className = 'result-message error';
          status.textContent = d.error || 'Failed';
          status.style.display = 'inline';
        }
      })
      .catch(function() {
        var status = document.getElementById('manualStatus');
        status.className = 'result-message error';
        status.textContent = 'Error';
        status.style.display = 'inline';
      });
    });

    function filterTable() {
      var query = document.getElementById('searchInput').value.toLowerCase();
      var typeFilter = document.getElementById('filterType').value;
      var statusFilter = document.getElementById('filterStatus').value;
      var rows = document.querySelectorAll('#contributorsTable tbody tr');
      var count = 0;
      rows.forEach(function(row) {
        var searchText = row.getAttribute('data-search').toLowerCase();
        var type = row.getAttribute('data-type');
        var status = row.getAttribute('data-status');
        var match = (!query || searchText.indexOf(query) !== -1) &&
                     (!typeFilter || type === typeFilter) &&
                     (!statusFilter || status === statusFilter);
        row.style.display = match ? '' : 'none';
        if (match) count++;
      });
      document.getElementById('filterCount').textContent = count + ' of ' + rows.length;
    }

    document.getElementById('searchInput').addEventListener('input', filterTable);
    document.getElementById('filterType').addEventListener('change', filterTable);
    document.getElementById('filterStatus').addEventListener('change', filterTable);
  </script>

  <div id="notifPanel" class="notif-panel">
    <div class="notif-panel-header">
      <h3>Notifications</h3>
      <button onclick="markAllRead()" class="btn btn-sm" style="background:none;color:#1a237e;font-size:0.75rem;padding:0;"><i class="fas fa-check-double"></i> Mark all read</button>
    </div>
    <div id="notifList" class="notif-list"><p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;">Loading...</p></div>
  </div>
  <div id="notifOverlay" class="notif-overlay" onclick="closeNotifications()"></div>

  <script>
    function toggleNotifications() {
      var panel = document.getElementById('notifPanel');
      var overlay = document.getElementById('notifOverlay');
      if (panel.classList.contains('open')) { panel.classList.remove('open'); overlay.style.display = 'none'; }
      else { loadNotifications(); panel.classList.add('open'); overlay.style.display = 'block'; }
    }
    function closeNotifications() {
      document.getElementById('notifPanel').classList.remove('open');
      document.getElementById('notifOverlay').style.display = 'none';
    }
    function loadNotifications() {
      var list = document.getElementById('notifList');
      list.innerHTML = '<p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;">Loading...</p>';
      fetch('/api/notifications').then(function(r){return r.json()}).then(function(data){
        list.innerHTML = '';
        if (data.notifications.length === 0) { list.innerHTML = '<p style="text-align:center;color:#888;padding:2rem;font-size:0.85rem;">No notifications yet.</p>'; return; }
        data.notifications.forEach(function(n){
          var d=new Date(n.created_at); var ds=d.toLocaleDateString()+' '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
          var icon=n.type==='new_promise'?'fa-handshake':n.type==='new_cash'?'fa-money-bill':'fa-check-circle';
          var item=document.createElement('div'); item.className='notif-item'+(n.is_read?'':' unread');
          item.innerHTML='<div class="notif-icon"><i class="fas '+icon+'"></i></div><div class="notif-body"><div class="notif-msg">'+n.message+'</div><div class="notif-time">'+ds+'</div></div>';
          list.appendChild(item);
        });
        document.getElementById('notifBadge').style.display='none';
      }).catch(function(){ list.innerHTML='<p style="text-align:center;color:#c62828;padding:1rem;font-size:0.85rem;">Failed to load.</p>'; });
    }
    function markAllRead() {
      fetch('/api/notifications/read',{method:'POST'}).then(function(r){return r.json()}).then(function(d){if(d.success){document.querySelectorAll('#notifList .notif-item').forEach(function(el){el.classList.remove('unread');});}}).catch(function(){});
    }
  </script>
</body>
</html>