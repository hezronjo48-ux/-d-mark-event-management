<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= __('activityLog') %> - <%= __('brand') %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .lang-toggle { font-size:0.75rem; font-weight:600; padding:0.25rem 0.6rem; border-radius:4px; border:1.5px solid rgba(255,255,255,0.4); color:#fff; background:transparent; cursor:pointer; transition:0.2s; }
    .lang-toggle:hover { background:rgba(255,255,255,0.15); }
  </style>
</head>
<body>
  <nav>
    <div class="nav-container">
      <div class="nav-brand"><%= __('brand') %></div>
      <div class="nav-links">
        <a href="/admin/dashboard"><%= __('dashboard') %></a>
        <a href="/admin/events/create"><%= __('createEvent') %></a>
        <a href="/admin/debtors"><%= __('debtors') %></a>
        <a href="/admin/activity-log" class="active"><%= __('activityLog') %></a>
        <a href="javascript:void(0)" onclick="toggleNotifications()" class="notif-bell" style="position:relative;">
          <i class="fas fa-bell"></i>
          <span id="notifBadge" class="notif-badge" style="<%= unreadCount > 0 ? '' : 'display:none;' %>"><%= unreadCount %></span>
        </a>
        <a href="javascript:void(0)" onclick="toggleLang()" class="lang-toggle"><%= lang === 'sw' ? 'EN' : 'SW' %></a>
        <a href="/admin/logout"><%= __('logout') %></a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <h1><%= __('activityLog') %></h1>
    </div>

    <% if (logs.length === 0) { %>
      <div class="empty-state"><p><%= __('noActivity') %></p></div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th><%= __('actionCol') %></th>
              <th><%= __('details') %></th>
              <th><%= __('dateTime') %></th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(function(log) { %>
              <tr>
                <td><span class="event-type-label"><%= log.action %></span></td>
                <td><%= log.details || '-' %></td>
                <td><%= new Date(log.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <div id="notifPanel" class="notif-panel">
    <div class="notif-panel-header">
      <h3><%= __('notifications') %></h3>
      <button onclick="markAllRead()" class="btn btn-sm" style="background:none;color:#1a237e;font-size:0.75rem;padding:0;"><i class="fas fa-check-double"></i> <%= __('markAllRead') %></button>
    </div>
    <div id="notifList" class="notif-list"><p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;"><%= __('loading') %></p></div>
  </div>
  <div id="notifOverlay" class="notif-overlay" onclick="closeNotifications()"></div>

  <script>
    function toggleLang() {
      var newLang = '<%= lang %>' === 'sw' ? 'en' : 'sw';
      fetch('/lang/' + newLang, { method: 'POST' }).then(function(r){return r.json()}).then(function(d){if(d.success)window.location.reload()}).catch(function(){});
    }
    function toggleNotifications() {
      var panel = document.getElementById('notifPanel');
      var overlay = document.getElementById('notifOverlay');
      if (panel.classList.contains('open')) { panel.classList.remove('open'); overlay.style.display = 'none'; }
      else { loadNotifications(); panel.classList.add('open'); overlay.style.display = 'block'; }
    }
    function closeNotifications() {
      document.getElementById('notifPanel').classList.remove('open');
      document.getElementById('notifOverlay').style.display = 'none';
    }
    function loadNotifications() {
      var list = document.getElementById('notifList');
      list.innerHTML = '<p style="text-align:center;color:#888;padding:1rem;font-size:0.85rem;"><%= __('loading') %></p>';
      fetch('/api/notifications').then(function(r){return r.json()}).then(function(data){
        list.innerHTML = '';
        if (data.notifications.length === 0) { list.innerHTML = '<p style="text-align:center;color:#888;padding:2rem;font-size:0.85rem;"><%= __('noNotifications') %></p>'; return; }
        data.notifications.forEach(function(n){
          var d=new Date(n.created_at); var ds=d.toLocaleDateString()+' '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
          var icon=n.type==='new_promise'?'fa-handshake':n.type==='new_cash'?'fa-money-bill':'fa-check-circle';
          var item=document.createElement('div'); item.className='notif-item'+(n.is_read?'':' unread');
          item.innerHTML='<div class="notif-icon"><i class="fas '+icon+'"></i></div><div class="notif-body"><div class="notif-msg">'+n.message+'</div><div class="notif-time">'+ds+'</div></div>';
          list.appendChild(item);
        });
        document.getElementById('notifBadge').style.display='none';
      }).catch(function(){ list.innerHTML='<p style="text-align:center;color:#c62828;padding:1rem;font-size:0.85rem;"><%= __('failedToLoad') %></p>'; });
    }
    function markAllRead() {
      fetch('/api/notifications/read',{method:'POST'}).then(function(r){return r.json()}).then(function(d){if(d.success){document.querySelectorAll('#notifList .notif-item').forEach(function(el){el.classList.remove('unread');});}}).catch(function(){});
    }
  </script>
</body>
</html>
